# ==============================================================
# BLUEPRINT KONFIGURASI (mikonku.ai-rag-service)
# ==============================================================
# Syarat: Ganti seluruh teks nama file ini dari ".env.example" menjadi ".env"

# --- [1] Database Vektor (ChromaDB) ---
# Alamat Podman/Lokal tempat rak memori vektor disimpan
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=document_collection

# --- [2] Mesin Pengekstrak Pemahaman Makna (Embeddings) ---
# Model HuggingFace ~90MB ini dipaksa lari di CPU agar tidak memakan VRAM GPU Anda
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# --- [3] Ketebalan Pemotongan Paragraf PDF (Text Splitter) ---
# Ukuran tiap paragraf yang disuapkan ke Ollama (Agar konteksnya pas)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- [4] Pembangkit Obrolan/Chatbot (LLM Inference) ---
# Pastikan Ollama Podman Anda sudah jalan!
OLLAMA_HOST=http://localhost:11434
# Kosakata Bahasa yang akan digenerate ke User
OLLAMA_MODEL_NAME=phi3
